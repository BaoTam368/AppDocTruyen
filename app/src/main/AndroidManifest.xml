            android:supportsRtl="true"
            android:theme="@style/Theme.AppDocTruyen"
            android:usesCleartextTraffic="true">
        <activity
                android:name="com.example.appdoctruyen.World.CreatePostActivity"
                android:exported="false"/>
        <activity
                android:name="com.example.appdoctruyen.views.activities.MainActivity"
                android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity
                android:name="com.example.appdoctruyen.views.activities.ComicDetailActivity"
                android:exported="false"/>
        <activity
                android:name="com.example.appdoctruyen.views.activities.ComicReadingActivity"
