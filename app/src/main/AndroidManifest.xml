        <activity
                android:name="com.example.appdoctruyen.views.activities.NewBookshelfActivity"
                android:exported="false"/>
        <activity
                android:name="com.example.appdoctruyen.views.activities.RankingActivity"
                android:exported="false"/>
        <activity
                android:name="com.example.appdoctruyen.views.activities.LoginActivity"
                android:exported="false"/>
        <activity
                android:name="com.example.appdoctruyen.views.activities.RegisterActivity"
                android:exported="false"/>
        <activity
                android:name="com.example.appdoctruyen.views.activities.PostDetailActivity"
