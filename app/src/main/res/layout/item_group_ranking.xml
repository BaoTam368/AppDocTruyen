<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- Số thứ hạng -->
    <TextView
        android:id="@+id/tvRankNumber"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/group_rank_number_placeholder"
        android:textColor="@color/brand_blue"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Avatar nhóm -->
    <ImageView
        android:id="@+id/imgRankAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:scaleType="centerCrop"
        android:src="@drawable/placeholder_group"
        android:background="@drawable/bg_card_comic"
        android:clipToOutline="true"
        android:contentDescription="@string/group_rank_avatar_content_description" />

    <!-- Thông tin nhóm -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRankGroupName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/group_name_placeholder"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvRankMemberCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/group_members_zero"
            android:textColor="@color/text_secondary_light"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Icon trophy cho top 3 -->
    <ImageView
        android:id="@+id/imgRankTrophy"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_trophy"
        android:visibility="gone"
        android:contentDescription="@string/group_trophy_content_description" />

</LinearLayout>
