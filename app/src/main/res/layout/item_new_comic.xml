<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_comic_row_cover"
        android:layout_width="85dp"
        android:layout_height="115dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_comic_row_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@color/bg_input_light" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_comic_row_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Võ Luyện Đỉnh Phong"
        android:textColor="@color/text_primary_light"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="@id/cv_comic_row_cover"
        app:layout_constraintStart_toEndOf="@id/cv_comic_row_cover"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_comic_row_chapter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Chapter 2315"
        android:textColor="@color/text_secondary_light"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tv_comic_row_title"
        app:layout_constraintStart_toStartOf="@id/tv_comic_row_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_comic_row_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Cập nhật lúc : 19:08 28/12/2024"
        android:textColor="@color/text_secondary_light"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tv_comic_row_chapter"
        app:layout_constraintStart_toStartOf="@id/tv_comic_row_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_comic_row_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Truyện tranh"
        android:textColor="@color/text_secondary_light"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tv_comic_row_time"
        app:layout_constraintStart_toStartOf="@id/tv_comic_row_title"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
