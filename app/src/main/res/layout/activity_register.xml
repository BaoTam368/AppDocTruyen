<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/register"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/windowBackground"
        android:padding="24dp">

    <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/title_app_motto"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            app:layout_constraintTop_toBottomOf="@id/iv_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
            android:id="@+id/tv_register_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/title_register"
            android:textSize="20sp"
            android:textColor="@color/text_primary_light"
            app:layout_constraintTop_toBottomOf="@id/tv_app_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
            android:id="@+id/edt_email_phone"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="24dp"
            android:background="@color/bg_input_light"
            android:hint="@string/hint_email"
            android:textColorHint="@color/hint_color_light"
            android:textColor="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_register_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
            android:id="@+id/edt_username"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@color/bg_input_light"
            android:hint="@string/hint_username"
            android:textColorHint="@color/hint_color_light"
            android:textColor="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/edt_email_phone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
            android:id="@+id/edt_password"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@color/bg_input_light"
            android:hint="@string/hint_password"
            android:textColorHint="@color/hint_color_light"
            android:textColor="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/edt_username"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
            android:id="@+id/edt_confirm_password"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@color/bg_input_light"
            android:hint="@string/hint_confirm_password"
            android:textColorHint="@color/hint_color_light"
            android:textColor="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/edt_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <Button
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/bg_button_light"
            android:text="@string/title_register"
            android:textColor="@color/text_primary_light"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/edt_confirm_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btn_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/bg_button_light"
        android:text="@string/btn_login"
        android:textColor="@color/text_primary_light"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/btn_register"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>