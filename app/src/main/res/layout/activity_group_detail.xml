<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="?android:attr/windowBackground">

    <!-- Header với nút back -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/brand_blue"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

        <ImageView
                android:id="@+id/btnBackGroupDetail"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="@string/action_back"
                android:tint="@color/white"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/group_detail_title"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
    </LinearLayout>

    <!-- Nội dung -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp">

            <!-- Avatar nhóm: FrameLayout chứa ImageView + TextView initials -->
            <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="16dp">

                <ImageView
                        android:id="@+id/imgGroupDetailAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/group_avatar_content_description"/>

                <TextView
                        android:id="@+id/tvGroupDetailInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/placeholder_group"
                        android:clipToOutline="true"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:visibility="visible"/>
            </FrameLayout>

            <!-- Tên nhóm -->
            <TextView
                    android:id="@+id/tvGroupDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/group_name_placeholder"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

            <!-- Mô tả nhóm -->
            <TextView
                    android:id="@+id/tvGroupDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/group_description_placeholder"
                    android:textColor="@color/text_secondary_light"
                    android:textSize="14sp"/>

            <!-- Thống kê -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                <!-- Số truyện -->
                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                    <TextView
                            android:id="@+id/tvGroupDetailComicCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/zero_count"
                            android:textColor="@color/brand_blue"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_comic_count"
                            android:textColor="@color/text_secondary_light"
                            android:textSize="13sp"/>
                </LinearLayout>

                <!-- Số thành viên -->
                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                    <TextView
                            android:id="@+id/tvGroupDetailMemberCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/zero_count"
                            android:textColor="@color/brand_blue"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_members"
                            android:textColor="@color/text_secondary_light"
                            android:textSize="13sp"/>
                </LinearLayout>

                <!-- Lượt theo dõi -->
                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                    <TextView
                            android:id="@+id/tvGroupDetailFollowerCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/zero_count"
                            android:textColor="@color/brand_blue"
                            android:textSize="24sp"
                            android:textStyle="bold"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_followers"
                            android:textColor="@color/text_secondary_light"
                            android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
