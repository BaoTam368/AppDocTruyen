<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="4dp"
              android:gravity="center_horizontal">

    <!-- Avatar nhóm: FrameLayout chứa ImageView + TextView initials -->
    <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp">

        <ImageView
                android:id="@+id/imgGroupAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_card_comic"
                android:clipToOutline="true"
                android:visibility="gone"
                android:contentDescription="@string/group_avatar_content_description"/>

        <TextView
                android:id="@+id/tvGroupInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:background="@drawable/placeholder_group"
                android:clipToOutline="true"
                android:text=""
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:visibility="visible"/>
    </FrameLayout>

    <!-- Tên nhóm -->
    <TextView
            android:id="@+id/tvGroupName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/group_name_placeholder"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"/>

    <!-- Hàng thông tin: số truyện + số thành viên -->
    <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

        <!-- Số truyện -->
        <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_comic"
                android:contentDescription="@string/label_comic_count_short"
                android:tint="@color/brand_blue"/>

        <TextView
                android:id="@+id/tvGroupComicCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="@string/zero_count"
                android:textColor="@color/text_secondary_light"
                android:textSize="11sp"/>

        <View
                android:layout_width="8dp"
                android:layout_height="1dp"/>

        <!-- Số thành viên -->
        <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_members"
                android:contentDescription="@string/label_members"
                android:tint="@color/brand_blue"/>

        <TextView
                android:id="@+id/tvGroupMemberCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="@string/zero_count"
                android:textColor="@color/text_secondary_light"
                android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>