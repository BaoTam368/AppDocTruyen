<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
                                       xmlns:app="http://schemas.android.com/apk/res-auto"
                                       xmlns:tools="http://schemas.android.com/tools"
                                       android:layout_width="match_parent"
                                       android:layout_height="match_parent"
                                       android:background="?android:attr/windowBackground">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

            <!-- Icon Avatar người dùng -->
            <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_user_avatar"/>

            <LinearLayout
                    android:id="@+id/layout_search_bar"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="12dp"
                    android:layout_weight="1"
                    android:background="@color/bg_input_light"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_search_category_default"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/hint_search_comic"
                        android:textColor="@color/text_secondary_light"
                        android:textSize="14sp"/>
            </LinearLayout>

            <ImageView
                    android:id="@+id/iv_refresh"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:src="@android:drawable/ic_popup_sync"/>

            <ImageView
                    android:id="@+id/iv_notification"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_notification"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Truyện nổi bật"
                    android:textColor="@color/text_primary_light"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_featured_comics"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_comic_large"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="18dp"
                android:paddingBottom="14dp"
                android:weightSum="4">

            <!-- Danh mục 1: Thể loại -->
            <LinearLayout
                    android:id="@+id/layout_cat_genres"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                <FrameLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_category_circle"
                        android:padding="12dp">

                    <ImageView
                            android:id="@+id/iv_cat_genres"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_cat_genres"/>
                </FrameLayout>

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/cat_genres"
                        android:textColor="@color/text_primary_light"
                        android:textSize="12sp"/>
            </LinearLayout>

            <!-- Danh mục 2: Top User -->
            <LinearLayout
                    android:id="@+id/layout_cat_top_user"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                <FrameLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_category_circle"
                        android:padding="12dp">

                    <ImageView
                            android:id="@+id/iv_cat_top_user"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_cat_top_user"/>
                </FrameLayout>

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/cat_top_user"
                        android:textColor="@color/text_primary_light"
                        android:textSize="12sp"/>
            </LinearLayout>

            <!-- Danh mục 3: Truyện mới -->
            <LinearLayout
                    android:id="@+id/layout_cat_new"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                <FrameLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_category_circle"
                        android:padding="12dp">

                    <ImageView
                            android:id="@+id/iv_cat_new"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_cat_new"/>
                </FrameLayout>

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/cat_new_comics"
                        android:textColor="@color/text_primary_light"
                        android:textSize="12sp"/>
            </LinearLayout>

            <!-- Danh mục 4: HOT -->
            <LinearLayout
                    android:id="@+id/layout_cat_hot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                <FrameLayout
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_category_circle"
                        android:padding="12dp">

                    <ImageView
                            android:id="@+id/iv_cat_hot"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_cat_hot"/>
                </FrameLayout>

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/cat_hot"
                        android:textColor="@color/text_primary_light"
                        android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_recently_updated"
                    android:textColor="@color/text_primary_light"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

            <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Xem thêm"
                    android:src="@drawable/ic_menu_forward"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recently_updated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:padding="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"
                tools:listitem="@layout/item_comic"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>