<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:orientation="vertical">

    <!-- 1. THANH HEADER XANH DƯƠNG -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_blue"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/iv_top_up_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_activity_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/title_user_fragment"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lbl_choose_payment_method"
            android:textColor="@color/text_primary_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/btn_pay_card"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_payment_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/method_phone_card"
                android:textColor="@color/text_primary_light"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_forward"
                app:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_pay_banking"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_payment_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/method_banking"
                android:textColor="@color/text_primary_light"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_forward"
                app:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_pay_momo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_payment_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/method_momo"
                android:textColor="@color/text_primary_light"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_forward"
                app:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_earn_coins"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_payment_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/method_earn_coins"
                android:textColor="@color/text_primary_light"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_forward"
                app:tint="@color/black" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lbl_notice_title"
            android:textColor="@color/notice_red"
            android:textSize="15sp"
            android:textStyle="bold|italic"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/note_rate_highlight"
                android:textColor="@color/brand_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/note_rate_rest"
                android:textColor="@color/text_primary_light"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/note_vip_info"
            android:textColor="@color/text_primary_light"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/note_ads_info"
            android:textColor="@color/text_primary_light"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.2" />

    </LinearLayout>
</LinearLayout>
